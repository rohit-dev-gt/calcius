# ─────────────────────────────────────────────────────────────────────────────
# Calcura — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node Environment ──────────────────────────────────────────────────────────
NODE_ENV=development

# ── Database (PostgreSQL via Supabase or local Docker) ───────────────────────
DATABASE_URL="postgresql://calcura:calcura_dev_password@localhost:5432/calcura_db"

# For Supabase (production):
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# ── Redis (local Docker or Upstash) ──────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# For Upstash (production):
# REDIS_URL="rediss://:[password]@[endpoint].upstash.io:6380"

# ── JWT Secrets ────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-this-to-a-long-random-string-for-access-tokens"
JWT_REFRESH_SECRET="change-this-to-a-different-long-random-string-for-refresh"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── API Server ─────────────────────────────────────────────────────────────────
PORT=3001
API_URL="http://localhost:3001"

# ── Frontend URL (for CORS) ────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"

# ── Supabase Storage (for future avatar uploads) ──────────────────────────────
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── Sentry (error tracking) ───────────────────────────────────────────────────
SENTRY_DSN=""
VITE_SENTRY_DSN=""

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
